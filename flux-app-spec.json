{
  "version": 8,
  "name": "basaltadmin",
  "description": "Grafana + Loki monitoring stack for Basalt Vultiserver",
  "owner": "",
  "instances": 1,
  "staticip": false,
  "enterprise": "",
  "compose": [
    {
      "name": "monitor",
      "description": "Grafana and Loki in a single container with nginx basic auth",
      "repotag": "ghcr.io/dc-codes426/basalt-admin:latest",
      "ports": [3000, 3100],
      "containerPorts": [3000, 3100],
      "domains": [""],
      "environmentParameters": [
        "GRAFANA_ADMIN_USER=admin",
        "GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password",
        "LOKI_AUTH_USER=loki",
        "LOKI_AUTH_PASSWORD=CHANGE_ME_loki_password",
        "GF_SERVER_ROOT_URL=https://basaltadmin.app.runonflux.io/",
        "HEALTHCHECK_TARGET_URL=CHANGE_ME_vultiserver_url",
        "HEALTHCHECK_INTERVAL=30"
      ],
      "commands": [],
      "containerData": "/loki",
      "cpu": 1.0,
      "ram": 2000,
      "hdd": 10,
      "tiered": false
    }
  ]
}
