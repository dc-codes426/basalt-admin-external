{
  "uid": "basalt-vultiserver",
  "title": "Basalt Vultiserver",
  "tags": ["basalt", "vultiserver", "loki"],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### Target: `__TARGET_URL__`"
      },
      "transparent": true
    },
    {
      "id": 5,
      "title": "Server Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "count_over_time({app=\"basalt-vultiserver\", service=\"healthcheck\", endpoint=\"ping\", level=\"info\"} [2m])",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "special", "options": { "match": "null", "result": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "range", "options": { "from": 1, "to": 999999, "result": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "noValue": "DOWN"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 7,
      "title": "Last Test Result",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 2 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "last_over_time({app=\"basalt-vultiserver\", service=\"testrunner\", test=\"_summary\"} | json | unwrap failed [$__range])",
          "legendFormat": "failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "PASS", "color": "green" } } },
            { "type": "range", "options": { "from": 1, "to": 999999, "result": { "text": "FAIL", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "No runs"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "background",
        "textMode": "value",
        "graphMode": "none"
      },
      "maxDataPoints": 1
    },
    {
      "id": 9,
      "title": "Last Run",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 2 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "last_over_time({app=\"basalt-vultiserver\", service=\"testrunner\", test=\"_summary\"} | json | unwrap failed [$__range])",
          "legendFormat": "last_run",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "color": { "fixedColor": "text", "mode": "fixed" },
          "noValue": "No runs"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/Time/"
        },
        "colorMode": "background",
        "textMode": "value",
        "graphMode": "none"
      },
      "maxDataPoints": 1
    },
    {
      "id": 8,
      "title": "Warnings (5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"basalt-vultiserver\", service!=\"healthcheck\", level=\"warning\"} [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["sum"] },
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "title": "Recent Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{app=\"basalt-vultiserver\", service!=\"healthcheck\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ],
  "schemaVersion": 39
}
