{
  "uid": "basalt-testrunner-prod",
  "title": "Basalt Test Runner (Prod)",
  "tags": ["basalt", "tests", "testrunner"],
  "timezone": "browser",
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Failed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(last_over_time({app=\"basalt-vultiserver\", service=\"testrunner\", test=\"_summary\"} | json | unwrap failed [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "title": "Passed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(last_over_time({app=\"basalt-vultiserver\", service=\"testrunner\", test=\"_summary\"} | json | unwrap passed [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "title": "Run Tests",
      "type": "text",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:center;justify-content:center;height:100%\"><button onclick=\"fetch('//' + window.location.hostname + ':8090/run').then(r=>r.json()).then(d=>{this.textContent='Triggered!';setTimeout(()=>{this.textContent='Run Tests Now'},2000)}).catch(()=>{this.textContent='Error';setTimeout(()=>{this.textContent='Run Tests Now'},2000)})\" style=\"padding:12px 24px;font-size:16px;font-weight:bold;color:#fff;background:#3871dc;border:none;border-radius:6px;cursor:pointer\">Run Tests Now</button></div>"
      }
    },
    {
      "id": 4,
      "title": "",
      "type": "text",
      "transparent": true,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "mode": "html",
        "content": "<div style=\"display:flex;align-items:baseline;gap:8px;padding:4px 0\"><span style=\"font-size:16px;font-weight:500\">Last Run</span><span id=\"last-run-age\" style=\"font-size:12px;color:#8e8e8e\"></span></div><script>!function(){var e=document.getElementById('last-run-age');function u(){fetch('//' + window.location.hostname + ':8090/status').then(r=>r.json()).then(d=>{if(d.last_run_epoch){var m=Math.round((Date.now()/1000-d.last_run_epoch)/60);e.textContent=m<1?'just now':m+' min ago'}else{e.textContent='never'}}).catch(()=>{e.textContent=''})}u();setInterval(u,15000)}()</script>"
      }
    },

    {
      "id": 10,
      "title": "API Basics",
      "type": "table",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{app=\"basalt-vultiserver\", service=\"testrunner\", suite=\"api_basics\", test!=\"_summary\"} | json passed, duration_ms",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "extractFields", "options": { "source": "labels", "replace": false } },
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "test": { "aggregations": [], "operation": "groupby" },
              "passed": { "aggregations": ["lastNotNull"], "operation": "aggregate" },
              "duration_ms": { "aggregations": ["lastNotNull"], "operation": "aggregate" }
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "indexByName": { "test": 0, "passed (lastNotNull)": 1, "duration_ms (lastNotNull)": 2 },
            "renameByName": { "test": "Test", "passed (lastNotNull)": "Result", "duration_ms (lastNotNull)": "ms" }
          }
        },
        { "id": "sortBy", "options": { "sort": [{ "field": "Test" }] } }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Result" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "mappings", "value": [{ "type": "value", "options": { "true": { "text": "PASS", "color": "green" }, "false": { "text": "FAIL", "color": "red" } } }] }
            ]
          }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": false } }
    },
